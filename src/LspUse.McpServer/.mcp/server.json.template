{
  "$schema": "https://modelcontextprotocol.io/schemas/draft/2025-07-09/server.json",
  "description": "An MCP server to bring the C# Language Server to LLMs",
  "name": "io.github.p1va/lsp-use",
  "packages": [
    {
      "registry_name": "nuget",
      "name": "{{PackageId}}",
      "version": "{{PackageVersion}}",
      "package_arguments": [
        {
          "description": "Path to solution file to open",
          "format": "string",
          "type": "positional",
          "value": "--sln",
          "value_hint": "--sln",
          "default": "--sln",
          "is_required": true
        },
        {
          "description": "Path to workspace to open",
          "format": "string",
          "type": "positional",
          "value": "--workspace",
          "value_hint": "--workspace",
          "default": "--workspace",
          "is_required": true
        }
      ],
      "environment_variables": []
    }
  ],
  "repository": {
    "url": "https://github.com/p1va/lsp-use",
    "source": "github"
  },
  "version_detail": {
    "version": "{{PackageVersion}}"
  }
}
